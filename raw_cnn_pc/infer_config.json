{
  "name": "raw_cnn_infer",
  "data": {
    "test_data_dir": "test_data",
    "base_window_size": 500,
    "base_step": 250,
    "sequence_length": 1,
    "sequence_step": 1
  },
  "preprocessing": {
    "feature_mode": "raw",
    "filter_type": "none"
  },
  "model": {
