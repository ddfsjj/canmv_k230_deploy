{
  "name": "raw_cnn_k230_export",
  "paths": {
    "weights_pth": "model/model_run020.pth",
    "onnx": "../raw_cnn_k230/model/model_run020.onnx",
    "kmodel": "../raw_cnn_k230/model/model_run020.kmodel",
    "scaler_pkl": "model/scaler_run020.pkl",
    "scaler_json": "../raw_cnn_k230/model/scaler_run020.json",
    "calibration_npy": "../raw_cnn_k230/model/calibration_input.npy",
    "test_data_dir": "test_data",
    "predictions_csv": "../raw_cnn_k230/predictions_k230.csv",
    "nncase_dump_dir": "../raw_cnn_k230/model/nncase_dump"
  },
  "data": {
    "base_window_size": 500,
    "base_step": 250,
    "sequence_length": 1,
    "sequence_step": 1
  },
  "preprocessing": {
    "feature_mode": "raw",
    "filter_type": "none"
  },
  "model": {
    "type": "CNN-All",
    "conv_filters": [
      32,
      64
    ],
    "kernel_size": 5,
    "pool_size": 1
  },
  "quantization": {
    "samples_count": 64,
    "quant_type": "uint8",
    "weight_quant_type": "uint8",
    "calibrate_method": "NoClip"
  }
}
