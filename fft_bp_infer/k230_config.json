{
  "name": "fft_bp_k230",
  "paths": {
    "weights_pth": "model/model_run000.pth",
    "onnx": "model/model_run000.onnx",
    "kmodel": "model/model_run000.kmodel",
    "scaler_pkl": "model/scaler_run000.pkl",
    "scaler_json": "model/scaler_run000.json",
    "calibration_npy": "model/calibration_input.npy",
    "test_data_dir": "test_data",
    "predictions_csv": "predictions_k230.csv",
    "nncase_dump_dir": "model/nncase_dump"
  },
  "data": {
    "base_window_size": 500,
    "base_step": 250,
    "sequence_length": 1,
    "sequence_step": 1
  },
  "preprocessing": {
    "feature_mode": "FFT Spectrum",
    "fft_config": {
      "fs": 1000,
      "f_min": 0.1,
      "f_max": 50,
      "window": "hann",
      "nfft": "auto"
    }
  },
  "model": {
    "type": "BP",
    "hidden_units": [
      32
    ],
    "activation": "tanh",
    "output_activation": "none"
  },
  "quantization": {
    "samples_count": 64,
    "quant_type": "uint8",
    "weight_quant_type": "uint8",
    "calibrate_method": "NoClip"
  }
}
